{
  "dart.flutterSdkPath": "",
  "dart.sdkPath": "",
  "dart.enableSdkFormatter": true,
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "Dart-Code.dart-code",
    "editor.codeActionsOnSave": {
      "source.fixAll.dart": true
    }
  },
  "editor.rulers": [
    80,
    120
  ],
  "files.exclude": {
    "**/.git": true,
    "**/.gitignore": true,
    "**/.metadata": true,
    "**/build": true,
    "**/.dart_tool": true,
    "**/.flutter-plugins": true,
    "**/.flutter-plugins-dependencies": true,
    "**/.packages": true,
    "**/.idea": true,
    "**/.vscode": false
  }
}